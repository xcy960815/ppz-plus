{
  "name": "ppz-plus",
  "displayName": "ppz-plus",
  "description": "Database import/export tools for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:ppz-plus.showProjectStatus",
    "onCommand:ppz-plus.addMySqlConnection",
    "onCommand:ppz-plus.manageMySqlConnections",
    "onCommand:ppz-plus.refreshMySqlConnectionsTree",
    "onCommand:ppz-plus.testStoredMySqlConnection",
    "onView:ppzPlus.mysqlConnections"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ppzPlus",
          "title": "PPZ Plus",
          "icon": "resources/ppz-plus.svg"
        }
      ]
    },
    "views": {
      "ppzPlus": [
        {
          "id": "ppzPlus.mysqlConnections",
          "name": "MySQL Connections"
        }
      ]
    },
    "commands": [
      {
        "command": "ppz-plus.addMySqlConnection",
        "title": "PPZ Plus: Add MySQL Connection"
      },
      {
        "command": "ppz-plus.manageMySqlConnections",
        "title": "PPZ Plus: Manage MySQL Connections"
      },
      {
        "command": "ppz-plus.refreshMySqlConnectionsTree",
        "title": "PPZ Plus: Refresh MySQL Connections"
      },
      {
        "command": "ppz-plus.testStoredMySqlConnection",
        "title": "PPZ Plus: Test Stored MySQL Connection"
      },
      {
        "command": "ppz-plus.showProjectStatus",
        "title": "PPZ Plus: Show Project Status"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ppz-plus.addMySqlConnection",
          "when": "view == ppzPlus.mysqlConnections",
          "group": "navigation@1"
        },
        {
          "command": "ppz-plus.refreshMySqlConnectionsTree",
          "when": "view == ppzPlus.mysqlConnections",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "ppz-plus.manageMySqlConnections",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlConnection",
          "group": "inline@1"
        },
        {
          "command": "ppz-plus.testStoredMySqlConnection",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlConnection",
          "group": "inline@2"
        },
        {
          "command": "ppz-plus.refreshMySqlConnectionsTree",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlConnection",
          "group": "inline@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
