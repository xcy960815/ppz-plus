{
  "name": "ppz-plus",
  "displayName": "ppz-plus",
  "description": "Database import/export tools for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:ppz-plus.showProjectStatus",
    "onCommand:ppz-plus.addMySqlConnection",
    "onCommand:ppz-plus.manageMySqlConnections"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ppz-plus.addMySqlConnection",
        "title": "PPZ Plus: Add MySQL Connection"
      },
      {
        "command": "ppz-plus.manageMySqlConnections",
        "title": "PPZ Plus: Manage MySQL Connections"
      },
      {
        "command": "ppz-plus.showProjectStatus",
        "title": "PPZ Plus: Show Project Status"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
