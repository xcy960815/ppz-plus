{
  "name": "ppz-plus",
  "displayName": "PPZ Plus",
  "description": "VS Code 数据库管理、导入导出工具",
  "version": "0.0.1",
  "publisher": "xcy960815",
  "icon": "resources/ppz-plus.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xcy960815/ppz-plus.git"
  },
  "bugs": {
    "url": "https://github.com/xcy960815/ppz-plus/issues"
  },
  "homepage": "https://xcy960815.github.io/ppz-plus/",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "database",
    "mysql",
    "postgresql",
    "sqlite",
    "sqlite3",
    "sql",
    "import",
    "export",
    "vscode database"
  ],
  "galleryBanner": {
    "color": "#174AA8",
    "theme": "dark"
  },
  "activationEvents": [
    "onWebviewPanel:ppzPlus.mysqlSqlTerminal",
    "onWebviewPanel:ppzPlus.postgreSqlSqlTerminal",
    "onWebviewPanel:ppzPlus.sqlite3SqlTerminal",
    "onWebviewPanel:ppzPlus.mysqlTableData"
  ],
  "dependencies": {
    "@vscode/sqlite3": "^5.1.14-vscode",
    "mssql": "12.7.0",
    "mysql2": "^3.11.3",
    "pg": "^8.22.0"
  },
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ppzPlus",
          "title": "PPZ Plus",
          "icon": "resources/ppz-plus-activity.svg"
        }
      ]
    },
    "views": {
      "ppzPlus": [
        {
          "id": "ppzPlus.mysqlConnections",
          "name": "数据库连接"
        },
        {
          "id": "ppzPlus.helpAndFeedback",
          "name": "帮助和反馈"
        }
      ]
    },
    "commands": [
      {
        "command": "ppz-plus.addMySqlConnection",
        "title": "新增数据库连接",
        "icon": "$(add)"
      },
      {
        "command": "ppz-plus.manageMySqlConnections",
        "title": "管理数据库连接",
        "icon": "$(settings-gear)"
      },
      {
        "command": "ppz-plus.refreshMySqlConnectionsTree",
        "title": "刷新数据库连接",
        "icon": "$(refresh)"
      },
      {
        "command": "ppz-plus.testStoredMySqlConnection",
        "title": "测试已保存的数据库连接",
        "icon": "$(beaker)"
      },
      {
        "command": "ppz-plus.uploadConnectionConfig",
        "title": "上传连接配置到 VS Code 账号",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "ppz-plus.pullConnectionConfig",
        "title": "从 VS Code 账号拉取连接配置",
        "icon": "$(cloud-download)"
      },
      {
        "command": "ppz-plus.openMySqlTableData",
        "title": "打开 MySQL 表数据",
        "icon": "$(table)"
      },
      {
        "command": "ppz-plus.openMySqlSqlTerminal",
        "title": "执行 MySQL SQL 语句",
        "icon": "$(terminal)"
      },
      {
        "command": "ppz-plus.openPostgreSqlSqlTerminal",
        "title": "打开 PostgreSQL SQL 终端",
        "icon": "$(terminal)"
      },
      {
        "command": "ppz-plus.addSqlite3Connection",
        "title": "新增 SQLite3 连接",
        "icon": "$(add)"
      },
      {
        "command": "ppz-plus.manageSqlite3Connections",
        "title": "管理 SQLite3 连接",
        "icon": "$(settings-gear)"
      },
      {
        "command": "ppz-plus.refreshSqlite3ConnectionsTree",
        "title": "刷新 SQLite3 连接",
        "icon": "$(refresh)"
      },
      {
        "command": "ppz-plus.testStoredSqlite3Connection",
        "title": "测试已保存的 SQLite3 连接",
        "icon": "$(beaker)"
      },
      {
        "command": "ppz-plus.openSqlite3SqlTerminal",
        "title": "打开 SQLite3 SQL 终端",
        "icon": "$(terminal)"
      },
      {
        "command": "ppz-plus.exportSqlite3TableDdl",
        "title": "导出 SQLite3 表 DDL",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportSqlite3TableDml",
        "title": "导出 SQLite3 表 DML",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportSqlite3TableBoth",
        "title": "导出 SQLite3 表 DDL + DML",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.importMySqlSqlFile",
        "title": "导入 MySQL SQL 文件",
        "icon": "$(file-code)"
      },
      {
        "command": "ppz-plus.importMySqlCsvFile",
        "title": "导入 MySQL CSV 文件",
        "icon": "$(file-code)"
      },
      {
        "command": "ppz-plus.importMySqlJsonFile",
        "title": "导入 MySQL JSON 文件",
        "icon": "$(file-code)"
      },
      {
        "command": "ppz-plus.exportMySqlTableDdl",
        "title": "导出 MySQL 表 DDL",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportMySqlTableDml",
        "title": "导出 MySQL 表 DML",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportMySqlTableBoth",
        "title": "导出 MySQL 表 DDL + DML",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportMySqlSchemaDdl",
        "title": "导出 MySQL Schema DDL",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportMySqlSchemaDml",
        "title": "导出 MySQL Schema DML",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportMySqlSchemaBoth",
        "title": "导出 MySQL Schema DDL + DML",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportMySqlTablesBatch",
        "title": "批量导出 MySQL 表",
        "icon": "$(save-all)"
      },
      {
        "command": "ppz-plus.exportPostgreSqlDatabaseDdl",
        "title": "导出 PostgreSQL Database DDL",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportPostgreSqlDatabaseDml",
        "title": "导出 PostgreSQL Database DML",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportPostgreSqlDatabaseBoth",
        "title": "导出 PostgreSQL Database DDL + DML",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportPostgreSqlSchemaDdl",
        "title": "导出 PostgreSQL Schema DDL",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportPostgreSqlSchemaDml",
        "title": "导出 PostgreSQL Schema DML",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportPostgreSqlSchemaBoth",
        "title": "导出 PostgreSQL Schema DDL + DML",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportPostgreSqlTableDdl",
        "title": "导出 PostgreSQL 表 DDL",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportPostgreSqlTableDml",
        "title": "导出 PostgreSQL 表 DML",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.exportPostgreSqlTableBoth",
        "title": "导出 PostgreSQL 表 DDL + DML",
        "icon": "$(save)"
      },
      {
        "command": "ppz-plus.showSqlExportTaskLogs",
        "title": "查看 SQL 导出日志",
        "icon": "$(history)"
      },
      {
        "command": "ppz-plus.showProjectStatus",
        "title": "查看项目状态",
        "icon": "$(info)"
      },
      {
        "command": "ppz-plus.clearPpzState",
        "title": "清空 PPZ Plus",
        "icon": "$(trash)"
      }
    ],
    "viewsWelcome": [
      {
        "view": "ppzPlus.helpAndFeedback",
        "contents": "简介：VS Code 数据库导入导出工具\n\n当前版本：v0.0.1\n\n[$(cloud-upload) 上传连接配置到 VS Code 账号](command:ppz-plus.uploadConnectionConfig)\n\n[$(cloud-download) 从 VS Code 账号拉取连接配置](command:ppz-plus.pullConnectionConfig)\n\n[$(github) GitHub](https://github.com/xcy960815/ppz-plus)\n\n[$(book) 使用帮助](https://xcy960815.github.io/ppz-plus/)\n\n[$(heart) 支持作者](https://xcy960815.github.io/ppz-plus/support)\n\n[$(comment-discussion) 反馈与 Bug](https://github.com/xcy960815/ppz-plus/issues/new)\n\n[$(trash) 清空 PPZ Plus](command:ppz-plus.clearPpzState)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ppz-plus.addMySqlConnection",
          "when": "view == ppzPlus.mysqlConnections",
          "group": "navigation@1"
        },
        {
          "command": "ppz-plus.refreshMySqlConnectionsTree",
          "when": "view == ppzPlus.mysqlConnections",
          "group": "navigation@2"
        },
        {
          "command": "ppz-plus.openMySqlSqlTerminal",
          "when": "view == ppzPlus.mysqlConnections",
          "group": "navigation@3"
        },
        {
          "command": "ppz-plus.showSqlExportTaskLogs",
          "when": "view == ppzPlus.mysqlConnections",
          "group": "navigation@4"
        },
        {
          "command": "ppz-plus.uploadConnectionConfig",
          "when": "view == ppzPlus.mysqlConnections",
          "group": "navigation@5"
        },
        {
          "command": "ppz-plus.pullConnectionConfig",
          "when": "view == ppzPlus.mysqlConnections",
          "group": "navigation@6"
        }
      ],
      "view/item/context": [
        {
          "command": "ppz-plus.manageMySqlConnections",
          "when": "view == ppzPlus.mysqlConnections && (viewItem == ppzPlus.mysqlConnection || viewItem == ppzPlus.postgresqlConnection || viewItem == ppzPlus.sqlite3Connection || viewItem == ppzPlus.mssqlConnection || viewItem == ppzPlus.plannedConnection)",
          "group": "1_manage@1"
        },
        {
          "command": "ppz-plus.testStoredMySqlConnection",
          "when": "view == ppzPlus.mysqlConnections && (viewItem == ppzPlus.mysqlConnection || viewItem == ppzPlus.postgresqlConnection || viewItem == ppzPlus.sqlite3Connection || viewItem == ppzPlus.mssqlConnection)",
          "group": "1_manage@2"
        },
        {
          "command": "ppz-plus.refreshMySqlConnectionsTree",
          "when": "view == ppzPlus.mysqlConnections && (viewItem == ppzPlus.mysqlConnection || viewItem == ppzPlus.postgresqlConnection || viewItem == ppzPlus.sqlite3Connection || viewItem == ppzPlus.mssqlConnection || viewItem == ppzPlus.plannedConnection)",
          "group": "2_action@1"
        },
        {
          "command": "ppz-plus.openSqlite3SqlTerminal",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.sqlite3Connection",
          "group": "inline@1"
        },
        {
          "command": "ppz-plus.openMySqlTableData",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.sqlite3Table",
          "group": "inline@1"
        },
        {
          "command": "ppz-plus.openSqlite3SqlTerminal",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.sqlite3Table",
          "group": "inline@2"
        },
        {
          "command": "ppz-plus.exportSqlite3TableDdl",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.sqlite3Table",
          "group": "export@1"
        },
        {
          "command": "ppz-plus.exportSqlite3TableDml",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.sqlite3Table",
          "group": "export@2"
        },
        {
          "command": "ppz-plus.exportSqlite3TableBoth",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.sqlite3Table",
          "group": "export@3"
        },
        {
          "command": "ppz-plus.openPostgreSqlSqlTerminal",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlConnection",
          "group": "inline@1"
        },
        {
          "command": "ppz-plus.openMySqlSqlTerminal",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlConnection",
          "group": "inline@1"
        },
        {
          "command": "ppz-plus.importMySqlSqlFile",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlConnection",
          "group": "import@1"
        },
        {
          "command": "ppz-plus.importMySqlCsvFile",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlConnection",
          "group": "import@2"
        },
        {
          "command": "ppz-plus.importMySqlJsonFile",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlConnection",
          "group": "import@3"
        },
        {
          "command": "ppz-plus.refreshMySqlConnectionsTree",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlDatabase",
          "group": "2_action@1"
        },
        {
          "command": "ppz-plus.openPostgreSqlSqlTerminal",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlDatabase",
          "group": "inline@1"
        },
        {
          "command": "ppz-plus.exportPostgreSqlDatabaseDdl",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlDatabase",
          "group": "export@1"
        },
        {
          "command": "ppz-plus.exportPostgreSqlDatabaseDml",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlDatabase",
          "group": "export@2"
        },
        {
          "command": "ppz-plus.exportPostgreSqlDatabaseBoth",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlDatabase",
          "group": "export@3"
        },
        {
          "command": "ppz-plus.refreshMySqlConnectionsTree",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlSchema",
          "group": "2_action@1"
        },
        {
          "command": "ppz-plus.openPostgreSqlSqlTerminal",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlSchema",
          "group": "inline@1"
        },
        {
          "command": "ppz-plus.exportPostgreSqlSchemaDdl",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlSchema",
          "group": "export@1"
        },
        {
          "command": "ppz-plus.exportPostgreSqlSchemaDml",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlSchema",
          "group": "export@2"
        },
        {
          "command": "ppz-plus.exportPostgreSqlSchemaBoth",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlSchema",
          "group": "export@3"
        },
        {
          "command": "ppz-plus.refreshMySqlConnectionsTree",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlTable",
          "group": "2_action@1"
        },
        {
          "command": "ppz-plus.openMySqlTableData",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlTable",
          "group": "inline@1"
        },
        {
          "command": "ppz-plus.openPostgreSqlSqlTerminal",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlTable",
          "group": "inline@2"
        },
        {
          "command": "ppz-plus.exportPostgreSqlTableDdl",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlTable",
          "group": "export@1"
        },
        {
          "command": "ppz-plus.exportPostgreSqlTableDml",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlTable",
          "group": "export@2"
        },
        {
          "command": "ppz-plus.exportPostgreSqlTableBoth",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.postgresqlTable",
          "group": "export@3"
        },
        {
          "command": "ppz-plus.refreshMySqlConnectionsTree",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlSchema",
          "group": "2_action@1"
        },
        {
          "command": "ppz-plus.openMySqlSqlTerminal",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlSchema",
          "group": "inline@1"
        },
        {
          "command": "ppz-plus.exportMySqlSchemaDdl",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlSchema",
          "group": "export@1"
        },
        {
          "command": "ppz-plus.exportMySqlSchemaDml",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlSchema",
          "group": "export@2"
        },
        {
          "command": "ppz-plus.exportMySqlSchemaBoth",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlSchema",
          "group": "export@3"
        },
        {
          "command": "ppz-plus.exportMySqlTablesBatch",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlSchema",
          "group": "export@4"
        },
        {
          "command": "ppz-plus.importMySqlSqlFile",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlSchema",
          "group": "import@1"
        },
        {
          "command": "ppz-plus.importMySqlCsvFile",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlSchema",
          "group": "import@2"
        },
        {
          "command": "ppz-plus.importMySqlJsonFile",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlSchema",
          "group": "import@3"
        },
        {
          "command": "ppz-plus.openMySqlTableData",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlTable",
          "group": "inline@1"
        },
        {
          "command": "ppz-plus.openMySqlSqlTerminal",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlTable",
          "group": "inline@2"
        },
        {
          "command": "ppz-plus.refreshMySqlConnectionsTree",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlTable",
          "group": "2_action@1"
        },
        {
          "command": "ppz-plus.importMySqlSqlFile",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlTable",
          "group": "import@1"
        },
        {
          "command": "ppz-plus.importMySqlCsvFile",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlTable",
          "group": "import@2"
        },
        {
          "command": "ppz-plus.importMySqlJsonFile",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlTable",
          "group": "import@3"
        },
        {
          "command": "ppz-plus.exportMySqlTableDdl",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlTable",
          "group": "export@1"
        },
        {
          "command": "ppz-plus.exportMySqlTableDml",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlTable",
          "group": "export@2"
        },
        {
          "command": "ppz-plus.exportMySqlTableBoth",
          "when": "view == ppzPlus.mysqlConnections && viewItem == ppzPlus.mysqlTable",
          "group": "export@3"
        }
      ]
    }
  },
  "scripts": {
    "preinstall": "node ./scripts/ensure-pnpm.cjs",
    "vscode:prepublish": "pnpm compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm compile && pnpm lint",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vscode-test",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:dry": "standard-version --dry-run",
    "changelog": "standard-version --skip.bump --skip.commit --skip.tag",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,json,md}": [
      "prettier --write"
    ],
    "*.ts": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "standard-version": "^9.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitepress": "^1.6.4",
    "vue": "^3.5.39"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
